default_platform(:android)

platform :android do
  desc "Run tests and build debug APK for CI"
  lane :ci do
    gradle(task: "clean")
    gradle(task: "test")
    gradle(task: "assembleDebug")
  end

  desc "Run tests, build signed release APK, and distribute to Firebase testers"
  lane :testers_build do
    gradle(task: "clean")
    gradle(task: "test")
    gradle(task: "assembleRelease")

    begin
      firebase_app_distribution(
        app: ENV["FIREBASE_APP_ID"],
        service_credentials_file: ENV["GOOGLE_APPLICATION_CREDENTIALS"],
        release_notes: ENV["FIREBASE_RELEASE_NOTES"] || "Automated tester build",
        groups: ENV["FIREBASE_GROUPS"] || "all-testers"
      )
    rescue StandardError => error
      UI.user_error!("Firebase App Distribution upload failed. Verify that the service account JSON in GOOGLE_APPLICATION_CREDENTIALS belongs to a service account that has Firebase App Distribution access on the target Firebase project, and confirm FIREBASE_APP_ID points to the same project. Original error: #{error.message}")
    end
  end

  desc "Build signed release artifacts"
  lane :release_build do
    gradle(task: "clean")
    gradle(task: "assembleRelease")
  end
end
